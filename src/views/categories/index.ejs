<%- include('../partials/header', { title: title }) %>
<%- include('../partials/navbar', { active: 'categories' }) %>

<%
  const isEdit = !!editing;
  const actionUrl = isEdit ? `/categories/${editing.id}` : '/categories';
%>

<div class="container">
  <h2>Categorias</h2>

  <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <div class="cat-layout">
    <div>
      <% if (categories.length === 0) { %>
        <table><tbody><tr><td class="empty">Nenhuma categoria ainda. Crie a primeira ao lado.</td></tr></tbody></table>
      <% } else { %>
        <table>
          <thead>
            <tr><th>Cor</th><th>Nome</th><th>Acoes</th></tr>
          </thead>
          <tbody>
            <% categories.forEach(function(c) { %>
              <tr>
                <td><span class="color-dot" style="background: <%= c.color %>"></span></td>
                <td><%= c.name %></td>
                <td>
                  <div class="actions">
                    <a href="/categories?edit=<%= c.id %>" class="btn btn-sm btn-warning">Editar</a>
                    <form action="/categories/<%= c.id %>/delete" method="POST" class="js-confirm-delete">
                      <button type="submit" class="btn btn-sm btn-danger">Excluir</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      <% } %>
    </div>

    <div class="card-box">
      <div class="section-title" style="margin-top:0;"><%= isEdit ? 'Editar categoria' : 'Nova categoria' %></div>
      <form action="<%= actionUrl %>" method="POST">
        <div class="form-group">
          <label for="name">Nome</label>
          <input type="text" id="name" name="name" value="<%= isEdit ? editing.name : '' %>" required>
        </div>
        <div class="form-group">
          <label for="color">Cor</label>
          <input type="color" id="color" name="color" value="<%= isEdit ? editing.color : '#6c757d' %>">
        </div>
        <button type="submit" class="btn"><%= isEdit ? 'Salvar' : 'Adicionar' %></button>
        <% if (isEdit) { %>
          <a href="/categories" class="btn btn-secondary">Cancelar</a>
        <% } %>
      </form>
    </div>
  </div>
</div>

<script src="/js/main.js"></script>
</body>
</html>
