<%- include('../partials/header', { title: title }) %>
<%- include('../partials/navbar', { active: 'tasks' }) %>

<%
  function fmtDate(iso) {
    if (!iso) return '-';
    const p = String(iso).slice(0, 10).split('-');
    return p.length === 3 ? `${p[2]}/${p[1]}/${p[0]}` : iso;
  }
%>

<div class="container">
  <div class="page-head">
    <h2>Minhas Tarefas</h2>
    <a href="/tasks/new" class="btn">+ Nova tarefa</a>
  </div>

  <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <form class="filters" method="GET" action="/tasks">
    <div class="form-group">
      <label>Status</label>
      <select name="status">
        <option value="">Todos</option>
        <% statuses.forEach(function(s) { %>
          <option value="<%= s %>" <%= filters.status === s ? 'selected' : '' %>><%= statusLabels[s] %></option>
        <% }); %>
      </select>
    </div>
    <div class="form-group">
      <label>Prioridade</label>
      <select name="priority">
        <option value="">Todas</option>
        <% priorities.forEach(function(p) { %>
          <option value="<%= p %>" <%= filters.priority === p ? 'selected' : '' %>><%= priorityLabels[p] %></option>
        <% }); %>
      </select>
    </div>
    <div class="form-group">
      <label>Categoria</label>
      <select name="category">
        <option value="">Todas</option>
        <% categories.forEach(function(c) { %>
          <option value="<%= c.id %>" <%= String(filters.categoryId) === String(c.id) ? 'selected' : '' %>><%= c.name %></option>
        <% }); %>
      </select>
    </div>
    <div class="form-group">
      <label>Buscar</label>
      <input type="text" name="search" value="<%= filters.search %>" placeholder="titulo ou descricao">
    </div>
    <div class="form-group">
      <button type="submit" class="btn">Filtrar</button>
    </div>
    <div class="form-group">
      <a href="/tasks" class="btn btn-secondary">Limpar</a>
    </div>
  </form>

  <% if (tasks.length === 0) { %>
    <table><tbody><tr><td class="empty">Nenhuma tarefa encontrada.</td></tr></tbody></table>
  <% } else { %>
    <table>
      <thead>
        <tr>
          <th>Titulo</th>
          <th>Categoria</th>
          <th>Prioridade</th>
          <th>Status</th>
          <th>Vencimento</th>
          <th>Acoes</th>
        </tr>
      </thead>
      <tbody>
        <% tasks.forEach(function(t) { %>
          <tr>
            <td><%= t.title %></td>
            <td>
              <% if (t.category_name) { %>
                <span class="color-dot" style="background: <%= t.category_color %>"></span><%= t.category_name %>
              <% } else { %>
                <span class="empty" style="padding:0;">-</span>
              <% } %>
            </td>
            <td><span class="badge <%= t.priority %>"><%= priorityLabels[t.priority] %></span></td>
            <td><span class="badge <%= t.status %>"><%= statusLabels[t.status] %></span></td>
            <td><%= fmtDate(t.due_date) %></td>
            <td>
              <div class="actions">
                <a href="/tasks/<%= t.id %>/edit" class="btn btn-sm btn-warning">Editar</a>
                <form action="/tasks/<%= t.id %>/delete" method="POST" class="js-confirm-delete">
                  <button type="submit" class="btn btn-sm btn-danger">Excluir</button>
                </form>
              </div>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>
</div>

<script src="/js/main.js"></script>
</body>
</html>
